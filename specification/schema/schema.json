{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-card.github.io/spec/sep-0015/schema.json",
  "title": "Converged AI Card Profile",
  "type": "object",
  "required": [
    "$schema",
    "specVersion",
    "cardVersion",
    "cardKind",
    "id",
    "name",
    "description",
    "publisher",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "specVersion": { "type": "string" },
    "cardVersion": { "type": "string" },
    "cardKind": { "type": "string", "enum": ["live-service", "data-asset", "hybrid"] },
    "id": { "type": "string", "format": "uri-reference" },
    "identityType": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "logoUrl": { "type": "string", "format": "uri-reference" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "maturity": { "type": "string", "enum": ["preview", "stable", "deprecated"] },
    "publisher": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "format": "uri-reference" },
        "identityType": { "type": "string" },
        "name": { "type": "string" },
        "attestation": { "$ref": "#/$defs/attestation" }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "properties": {
        "attestations": {
          "type": "array",
          "items": { "$ref": "#/$defs/attestation" }
        },
        "privacyPolicyUrl": { "type": "string", "format": "uri-reference" },
        "termsOfServiceUrl": { "type": "string", "format": "uri-reference" }
      },
      "additionalProperties": false
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format", "value", "keyId", "createdAt"],
        "properties": {
          "format": { "type": "string" },
          "value": { "type": "string" },
          "keyId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version", "data"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "required": { "type": "boolean" },
          "digest": { "type": "string" },
          "data": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "locators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "role", "uri"],
        "properties": {
          "type": { "type": "string" },
          "role": { "type": "string", "enum": ["card", "catalog", "api", "artifact"] },
          "uri": { "type": "string", "format": "uri-reference" },
          "digest": { "type": "string" },
          "mediaType": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["uri", "mediaType"],
        "properties": {
          "uri": { "type": "string", "format": "uri-reference" },
          "mediaType": { "type": "string" },
          "digest": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "schemaUri": { "type": "string", "format": "uri-reference" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "cardKind": { "const": "data-asset" }
        },
        "required": ["cardKind"]
      },
      "then": {
        "required": ["artifacts"]
      }
    }
  ],
  "$defs": {
    "attestation": {
      "type": "object",
      "required": ["type", "uri", "mediaType"],
      "properties": {
        "type": { "type": "string" },
        "uri": { "type": "string", "format": "uri-reference" },
        "mediaType": { "type": "string" },
        "digest": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
