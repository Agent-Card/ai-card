{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-card.github.io/spec/sep-0015/schema.json",
  "title": "AI Manifest (OCI Image Manifest)",
  "description": "Schema for an OCI Image Manifest representing an AI agent or artifact.",
  "type": "object",
  "required": ["schemaVersion", "mediaType", "artifactType", "config", "layers", "annotations"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "mediaType": {
      "type": "string",
      "const": "application/vnd.oci.image.manifest.v1+json"
    },
    "artifactType": {
      "type": "string",
      "const": "application/vnd.lf.ai.manifest.v1+json"
    },
    "config": { "$ref": "#/$defs/descriptor" },
    "layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/descriptor" }
    },
    "annotations": {
      "type": "object",
      "required": [
        "org.opencontainers.image.title",
        "org.opencontainers.image.created",
        "org.lf.ai.card.id",
        "org.lf.ai.card.specVersion"
      ],
      "properties": {
        "org.opencontainers.image.title": { "type": "string" },
        "org.opencontainers.image.description": { "type": "string" },
        "org.opencontainers.image.created": { "type": "string", "format": "date-time" },
        "org.opencontainers.image.version": { "type": "string" },
        "org.opencontainers.image.vendor": { "type": "string" },
        "org.lf.ai.card.id": {
          "type": "string",
          "format": "uri-reference",
          "description": "Globally unique logical identifier (name) for the subject, such as a DID or URN."
        },
        "org.lf.ai.card.specVersion": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "subject": { "$ref": "#/$defs/descriptor" }
  },
  "additionalProperties": false,
  "$defs": {
    "descriptor": {
      "type": "object",
      "required": ["mediaType", "digest", "size"],
      "properties": {
        "mediaType": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^[a-z0-9]+:[a-f0-9]+$",
          "description": "Content-addressable digest in the form algorithm:hex."
        },
        "size": { "type": "integer", "minimum": 0 },
        "urls": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "artifactType": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
