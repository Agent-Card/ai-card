{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-card.github.io/spec/sep-0015/schema.json",
  "title": "Converged AI Card",
  "type": "object",
  "required": [
    "$schema",
    "specVersion",
    "cardVersion",
    "id",
    "name",
    "description",
    "publisher",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "specVersion": { "type": "string" },
    "cardVersion": { "type": "string" },
    "id": {
      "type": "string",
      "format": "uri-reference",
      "description": "Logical identifier for the subject (name), such as a URN or DID."
    },
    "identifierType": {
      "type": "string",
      "description": "Verification domain or scheme hint for validating the identifier or signature binding."
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "logoUrl": { "type": "string", "format": "uri-reference" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "domains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true
    },
    "maturity": { "type": "string", "enum": ["preview", "stable", "deprecated"] },
    "publisher": { "$ref": "#/$defs/publisher" },
    "trust": { "$ref": "#/$defs/trust" },
    "signatures": { "$ref": "#/$defs/signatures" },
    "modules": { "$ref": "#/$defs/moduleMap" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "publisher": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri-reference",
          "description": "Publisher identifier (logical name) such as a URN or DID."
        },
        "identifierType": {
          "type": "string",
          "description": "Verification domain or scheme hint for publisher identity."
        },
        "name": { "type": "string" },
        "attestation": { "$ref": "#/$defs/attestation" }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "properties": {
        "trustSchema": { "$ref": "#/$defs/trustSchema" },
        "attestations": {
          "type": "array",
          "items": { "$ref": "#/$defs/attestation" }
        },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/provenanceLink" }
        },
        "privacyPolicyUrl": { "type": "string", "format": "uri-reference" },
        "termsOfServiceUrl": { "type": "string", "format": "uri-reference" }
      },
      "additionalProperties": false
    },
    "trustSchema": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "format": "uri-reference" },
        "version": { "type": "string" },
        "governanceUri": { "type": "string", "format": "uri-reference" },
        "verificationMethods": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "provenanceLink": {
      "type": "object",
      "required": ["relation", "sourceId"],
      "properties": {
        "relation": { "type": "string" },
        "sourceId": { "type": "string", "format": "uri-reference" },
        "sourceDigest": { "type": "string" },
        "registryUri": { "type": "string", "format": "uri-reference" },
        "statementUri": { "type": "string", "format": "uri-reference" },
        "signatureRef": { "type": "string" }
      },
      "additionalProperties": false
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format", "value", "keyId", "createdAt"],
        "properties": {
          "format": { "type": "string" },
          "value": { "type": "string" },
          "keyId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "module": {
      "type": "object",
      "required": ["id", "version", "data"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "required": { "type": "boolean" },
        "digest": { "type": "string" },
        "data": { "type": "object" }
      },
      "additionalProperties": false
    },
    "moduleMap": {
      "type": "object",
      "properties": {
        "protocols": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/module" }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/module" }
        }
      },
      "additionalProperties": false
    },
    "attestation": {
      "type": "object",
      "required": ["type", "uri", "mediaType"],
      "properties": {
        "type": { "type": "string" },
        "uri": { "type": "string", "format": "uri-reference" },
        "mediaType": { "type": "string" },
        "digest": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
