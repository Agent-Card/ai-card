{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-card.github.io/spec/sep-0015/catalog-schema.json",
  "title": "AI Catalog (OCI Image Index)",
  "description": "Schema for an OCI Image Index representing an AI catalog.",
  "type": "object",
  "required": ["schemaVersion", "mediaType", "artifactType", "manifests"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "mediaType": {
      "type": "string",
      "const": "application/vnd.oci.image.index.v1+json"
    },
    "artifactType": {
      "type": "string",
      "const": "application/vnd.aaif.ai.catalog.v1+json"
    },
    "manifests": {
      "type": "array",
      "items": { "$ref": "#/$defs/manifestDescriptor" }
    },
    "annotations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "subject": { "$ref": "#/$defs/descriptor" }
  },
  "additionalProperties": false,
  "$defs": {
    "descriptor": {
      "type": "object",
      "required": ["mediaType", "digest", "size"],
      "properties": {
        "mediaType": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^[a-z0-9]+:[a-f0-9]+$"
        },
        "size": { "type": "integer", "minimum": 0 },
        "urls": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "artifactType": { "type": "string" }
      },
      "additionalProperties": false
    },
    "manifestDescriptor": {
      "type": "object",
      "required": ["mediaType", "artifactType", "digest", "size"],
      "properties": {
        "mediaType": {
          "type": "string",
          "const": "application/vnd.oci.image.manifest.v1+json"
        },
        "artifactType": {
          "type": "string",
          "const": "application/vnd.aaif.ai.manifest.v1+json"
        },
        "digest": {
          "type": "string",
          "pattern": "^[a-z0-9]+:[a-f0-9]+$"
        },
        "size": { "type": "integer", "minimum": 0 },
        "urls": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "HTTP URLs for well-known serving mode."
        },
        "annotations": {
          "type": "object",
          "properties": {
            "org.aaif.ai.card.id": {
              "type": "string",
              "format": "uri-reference"
            }
          },
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
