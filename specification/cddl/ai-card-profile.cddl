; ==========================================================================
; SEP-0015 Converged AI Card Profile CDDL
; ==========================================================================

AICard = {
  $schema: text,
  specVersion: text,
  cardVersion: text,
  id: text,
  ? identityType: text,
  name: text,
  description: text,
  ? logoUrl: text,
  ? tags: [* text],
  ? domains: [* text],
  ? skills: [* text],
  ? capabilities: { * text => any },
  ? maturity: "preview" / "stable" / "deprecated",
  publisher: Publisher,
  ? trust: Trust,
  ? signatures: [* Signature],
  ? modules: ModuleMap,
  ? metadata: { * text => any },
  createdAt: tdate,
  updatedAt: tdate
}

Publisher = {
  id: text,
  name: text,
  ? identityType: text,
  ? attestation: Attestation
}

Trust = {
  ? attestations: [* Attestation],
  ? privacyPolicyUrl: text,
  ? termsOfServiceUrl: text
}

Attestation = {
  type: text,
  uri: text,
  mediaType: text,
  ? digest: text,
  ? size: uint,
  ? description: text
}

Signature = {
  format: text,
  value: text,
  keyId: text,
  createdAt: tdate
}

Module = {
  id: text,
  version: text,
  ? required: bool,
  ? digest: text,
  data: { * text => any }
}

ModuleMap = {
  ? protocols: { * text => Module },
  ? artifacts: { * text => Module }
}

