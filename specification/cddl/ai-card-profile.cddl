; ==========================================================================
; SEP-0015 AI Manifest Profile CDDL (OCI Image Manifest)
; ==========================================================================

AIManifest = {
  schemaVersion: 2,
  mediaType: "application/vnd.oci.image.manifest.v1+json",
  artifactType: "application/vnd.aaif.ai.manifest.v1+json",
  config: Descriptor,
  layers: [* Descriptor],
  annotations: ManifestAnnotations,
  ? subject: Descriptor
}

ManifestAnnotations = {
  "org.aaif.ai.card.id" => text,
  "org.aaif.ai.card.specVersion" => text,
  * text => text
}

Descriptor = {
  mediaType: text,
  digest: text,
  size: uint,
  ? urls: [* text],
  ? annotations: { * text => text },
  ? artifactType: text
}

; ==========================================================================
; AI Card Config Blob (application/vnd.aaif.ai.card.config.v1+json)
; ==========================================================================

AICardConfig = {
  specVersion: text,
  descriptor: CardDescriptor
}

CardDescriptor = {
  id: text,
  ? identifierType: text,
  name: text,
  description: text,
  ? logoUrl: text,
  ? tags: [* text],
  ? domains: [* text],
  ? skills: [* text],
  ? capabilities: { * text => any },
  ? maturity: "preview" / "stable" / "deprecated",
  publisher: Publisher,
  createdAt: tdate,
  updatedAt: tdate
}

Publisher = {
  id: text,
  name: text,
  ? identifierType: text
}
