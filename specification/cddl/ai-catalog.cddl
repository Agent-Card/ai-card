; ==========================================================================
; SEP-0015 AI Catalog CDDL (OCI Image Index)
; ==========================================================================

AICatalog = {
  schemaVersion: 2,
  mediaType: "application/vnd.oci.image.index.v1+json",
  artifactType: "application/vnd.aaif.ai.catalog.v1+json",
  manifests: [* ManifestDescriptor],
  ? annotations: CatalogAnnotations,
  ? subject: Descriptor
}

ManifestDescriptor = {
  mediaType: "application/vnd.oci.image.manifest.v1+json",
  artifactType: "application/vnd.aaif.ai.manifest.v1+json",
  digest: text,
  size: uint,
  ? urls: [* text],
  ? annotations: ManifestEntryAnnotations
}

ManifestEntryAnnotations = {
  ? "org.aaif.ai.card.id" => text,
  * text => text
}

CatalogAnnotations = {
  * text => text
}

Descriptor = {
  mediaType: text,
  digest: text,
  size: uint,
  ? urls: [* text],
  ? annotations: { * text => text },
  ? artifactType: text
}
